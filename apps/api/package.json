{
  "name": "@lighter-bot/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "start:simulate": "DRY_RUN=true PAPER_TRADING=true node dist/server.js",
    "start:railway": "prisma db push --accept-data-loss && node dist/server.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@lighter-bot/common": "workspace:*",
    "@lighter-bot/strategy": "workspace:*",
    "@lighter-bot/risk": "workspace:*",
    "@lighter-bot/execution": "workspace:*",
    "@lighter-bot/backtest": "workspace:*",
    "fastify": "^5.2.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/jwt": "^9.0.1",
    "@fastify/websocket": "^11.0.1",
    "@fastify/rate-limit": "^10.2.1",
    "@fastify/swagger": "^9.4.0",
    "@prisma/client": "^6.2.1",
    "decimal.js": "^10.4.3",
    "pino": "^9.6.0",
    "zod": "^3.24.1",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "tsx": "^4.19.2",
    "prisma": "^6.2.1",
    "vitest": "^2.1.8"
  }
}
